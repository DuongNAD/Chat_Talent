# ============================================
# Chat_Talent V2.0 PRO — Environment Variables
# ============================================
# Copy file này thành .env rồi điền giá trị thật

# --- Database ---
DB_USER=chattalent
DB_PASSWORD=CHANGE_ME_strong_password_here

# --- Auth ---
JWT_SECRET=CHANGE_ME_random_64_char_string
JWT_REFRESH_SECRET=CHANGE_ME_another_random_64_char_string
INVITE_MASTER_KEY=CHANGE_ME_admin_secret_key

# --- OpenAI (thêm sau ở MVP 3) ---
# OPENAI_API_KEY=sk-...

# --- Cloudflare Tunnel (thêm sau ở Bước 5) ---
# CF_TUNNEL_TOKEN=eyJ...

# --- FFmpeg Hardware Acceleration ---
# cuda = NVIDIA GPU | qsv = Intel iGPU | none = CPU only
FFMPEG_HWACCEL=none
